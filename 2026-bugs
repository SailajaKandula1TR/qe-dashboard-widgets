<!-- DASHBOARD JS -->
<script>
(function(){
  function pd(id){ try{ return JSON.parse(document.getElementById(id).textContent); }catch(e){ return null; } }

  var AREA_LABELS    = pd('d-area-labels');
  var AREA_DATASETS  = pd('d-area-datasets');
  var FUNC_LABELS    = pd('d-func-labels');
  var FUNC_DATASETS  = pd('d-func-datasets');
  var RC_LABELS      = pd('d-rc-labels');
  var RC_COUNTS      = pd('d-rc-counts');
  var RC_PROD        = pd('d-rc-prod');
  var RC_INTL        = pd('d-rc-intl');
  var DC_LABELS      = pd('d-dc-labels');
  var DC_OPEN        = pd('d-dc-open');
  var DC_CLOSED      = pd('d-dc-closed');
  var AP_OPENTESTBUGS = pd('d-ap-opentestbugs') || [];

  // ── Cluster card toggle ────────────────────────────────────────────────
  window.toggleCard = function(id) {
    var body = document.getElementById(id);
    var ico  = document.getElementById(id + '-ico');
    if (!body) return;
    var open = body.style.display !== 'none';
    body.style.display = open ? 'none' : 'block';
    if (ico) ico.textContent = open ? '▼' : '▲';
  };

  var STACKED_OPTS = {
    responsive:true, maintainAspectRatio:false,
    plugins:{ legend:{ position:'bottom', labels:{ boxWidth:12, font:{ size:11 } } },
              tooltip:{ mode:'index', intersect:false,
                callbacks:{
                  footer: function(items){
                    var total = items.reduce(function(s,i){ return s+i.parsed.y; }, 0);
                    return 'Total: ' + total;
                  }
                }
              }
    },
    scales:{
      x:{ stacked:true, ticks:{ font:{ size:10 }, maxRotation:45 } },
      y:{ stacked:true, beginAtZero:true, ticks:{ font:{ size:11 } } }
    }
  };

  // ── Lazy chart registry — build charts only when their tab is visible ──
  var _chartInited = {};

  function buildTabCharts(id) {
    if (_chartInited[id]) return;
    _chartInited[id] = true;
    if (id === 'area') {
      new Chart(document.getElementById('cArea'), {
        type:'bar',
        data:{ labels: AREA_LABELS, datasets: AREA_DATASETS },
        options: STACKED_OPTS
      });
    } else if (id === 'func') {
      new Chart(document.getElementById('cFunc'), {
        type:'bar',
        data:{ labels: FUNC_LABELS, datasets: FUNC_DATASETS },
        options: STACKED_OPTS
      });
    } else if (id === 'rc') {
      new Chart(document.getElementById('cRCBar'), {
        type:'bar',
        data:{
          labels: RC_LABELS,
          datasets:[
            { label:'Production', data: RC_PROD, backgroundColor:'rgba(198,40,40,.82)', stack:'s', borderRadius:3 },
            { label:'Internal',   data: RC_INTL, backgroundColor:'rgba(46,125,50,.78)', stack:'s', borderRadius:3 }
          ]
        },
        options:{
          responsive:true, maintainAspectRatio:false,
          plugins:{ legend:{ position:'bottom', labels:{ boxWidth:10, font:{ size:11 } } },
                    tooltip:{ mode:'index', intersect:false } },
          scales:{
            x:{ stacked:true, beginAtZero:true, ticks:{ font:{ size:10 }, maxRotation:45 } },
            y:{ stacked:true, beginAtZero:true, ticks:{ font:{ size:10 } } }
          }
        }
      });
    } else if (id === 'pat') {
      new Chart(document.getElementById('cDCBar'), {
        type:'bar',
        data:{
          labels: DC_LABELS,
          datasets:[
            { label:'Open',   data: DC_OPEN,   backgroundColor:'rgba(230,81,0,.8)',   stack:'s', borderRadius:3 },
            { label:'Closed', data: DC_CLOSED, backgroundColor:'rgba(46,125,50,.75)', stack:'s', borderRadius:3 }
          ]
        },
        options:{
          responsive:true, maintainAspectRatio:false,
          plugins:{ legend:{ position:'bottom', labels:{ boxWidth:10, font:{ size:11 } } },
                    tooltip:{ mode:'index', intersect:false } },
          scales:{
            x:{ stacked:true, beginAtZero:true, ticks:{ font:{ size:10 }, maxRotation:45 } },
            y:{ stacked:true, beginAtZero:true, ticks:{ font:{ size:10 } } }
          }
        }
      });
    } else if (id === 'testaut') {
      buildTestAutCharts();
    }
  }

  // ── Tab switching — lazy-init charts on first show ─────────────────────
  window.showTab = function(id) {
    document.querySelectorAll('.tab-panel').forEach(function(p){ p.classList.remove('active'); });
    document.querySelectorAll('.tab-btn').forEach(function(b){ b.classList.remove('active'); });
    document.getElementById('tab-'+id).classList.add('active');
    document.querySelectorAll('.tab-btn').forEach(function(b){
      if(b.getAttribute('onclick') && b.getAttribute('onclick').indexOf("'"+id+"'") >= 0)
        b.classList.add('active');
    });
    buildTabCharts(id);
  };

  // Build default (active) tab chart immediately
  buildTabCharts('area');

  // ── Test Automation tab charts ─────────────────────────────────────────
  function buildTestAutCharts(){
    if (!AP_OPENTESTBUGS || !AP_OPENTESTBUGS.length) {
      var tbl = document.getElementById('aptaTable');
      if (tbl) tbl.innerHTML = '<p style="color:#888;padding:20px">No open bugs with linked tests found.</p>';
      return;
    }

    var STATUS_COLORS = {
      'Automated':                          '#1b5e20',
      'Automated-UI':                       '#2e7d32',
      'Automated-API':                      '#43a047',
      'Automated(Old Framework)':           '#66bb6a',
      'Automated in Integration Framework': '#81c784',
      'Partially Automated':                '#a5d6a7',
      'Planned':                            '#f9a825',
      'TBD':                                '#29b6f6',
      'Requires Automation':                '#0277bd',
      'Ready for EPAM Automation':          '#0288d1',
      'Manual':                             '#546e7a',
      'Not Automated':                      '#e53935',
      'Not Set':                            '#9e9e9e',
      'No Tests':                           '#bdbdbd'
    };
    function statusColor(s){ return STATUS_COLORS[s] || '#78909c'; }

    function possibleFix(desc){
      if (!desc) return '';
      var txt = desc.replace(/<[^>]+>/g,' ').replace(/&nbsp;/g,' ').replace(/&amp;/g,'&')
                    .replace(/&lt;/g,'<').replace(/&gt;/g,'>').replace(/s+/g,' ').trim();
      var sents = txt.split(/[.!?]s+/);
      for (var i=0;i<sents.length;i++){
        var s = sents[i].trim();
        if (s.length > 20){ return s.length > 120 ? s.slice(0,120)+'…' : s; }
      }
      return txt.length > 120 ? txt.slice(0,120)+'…' : txt;
    }

    // Aggregate by areaShort
    var areaMap = {};
    AP_OPENTESTBUGS.forEach(function(b){
      var area = b.areaShort || b.areaPath || 'Unknown';
      if (!areaMap[area]) areaMap[area] = { total:0, statusCounts:{} };
      areaMap[area].total++;
      var tests = b.tests || [];
      if (!tests.length){
        areaMap[area].statusCounts['No Tests'] = (areaMap[area].statusCounts['No Tests']||0)+1;
      } else {
        tests.forEach(function(t){
          var st = t.automationStatus || 'Not Set';
          areaMap[area].statusCounts[st] = (areaMap[area].statusCounts[st]||0)+1;
        });
      }
    });

    // Sort by total desc, take top 20
    var areaSorted = Object.keys(areaMap).sort(function(a,b){ return areaMap[b].total - areaMap[a].total; }).slice(0,20);
    var allStatuses = Object.keys(STATUS_COLORS);

    // Build stacked horizontal bar
    var barDatasets = allStatuses.map(function(st){
      return {
        label: st,
        data: areaSorted.map(function(a){ return areaMap[a].statusCounts[st]||0; }),
        backgroundColor: STATUS_COLORS[st],
        borderRadius: 3,
        stack: 's'
      };
    }).filter(function(ds){ return ds.data.some(function(v){ return v>0; }); });

    new Chart(document.getElementById('cAPTestAutoBar'), {
      type:'bar',
      data:{ labels: areaSorted, datasets: barDatasets },
      options:{
        indexAxis:'y',
        responsive:true, maintainAspectRatio:false,
        plugins:{
          legend:{ position:'bottom', labels:{ boxWidth:10, font:{ size:10 } } },
          tooltip:{ mode:'index', intersect:false }
        },
        scales:{
          x:{ stacked:true, beginAtZero:true, ticks:{ font:{ size:10 } } },
          y:{ stacked:true, ticks:{ font:{ size:10 } } }
        }
      }
    });

    // Overall donut
    var overallCounts = {};
    AP_OPENTESTBUGS.forEach(function(b){
      var tests = b.tests || [];
      if (!tests.length){
        overallCounts['No Tests'] = (overallCounts['No Tests']||0)+1;
      } else {
        tests.forEach(function(t){
          var st = t.automationStatus || 'Not Set';
          overallCounts[st] = (overallCounts[st]||0)+1;
        });
      }
    });
    var donutLabels = Object.keys(overallCounts);
    new Chart(document.getElementById('cAPTestAutoDonut'), {
      type:'doughnut',
      data:{
        labels: donutLabels,
        datasets:[{ data: donutLabels.map(function(l){ return overallCounts[l]; }),
                    backgroundColor: donutLabels.map(statusColor), borderWidth:1 }]
      },
      options:{
        responsive:true, maintainAspectRatio:false,
        plugins:{ legend:{ position:'bottom', labels:{ boxWidth:10, font:{ size:10 } } },
                  tooltip:{ callbacks:{ label:function(ctx){ return ctx.label+': '+ctx.parsed; } } } }
      }
    });

    // Populate filters
    function populateSelect(id, values){
      var sel = document.getElementById(id);
      if (!sel) return;
      var existing = Array.from(sel.options).map(function(o){ return o.value; });
      values.forEach(function(v){
        if (v && existing.indexOf(v)<0){
          var o = document.createElement('option'); o.value=v; o.textContent=v; sel.appendChild(o);
        }
      });
    }
    var areas = [...new Set(AP_OPENTESTBUGS.map(function(b){ return b.areaShort||b.areaPath||''; }))].sort();
    var funcs = [...new Set(AP_OPENTESTBUGS.map(function(b){ return b.functionality||''; }))].sort();
    var statuses = [...new Set(AP_OPENTESTBUGS.flatMap(function(b){ return (b.tests||[]).map(function(t){ return t.automationStatus||'Not Set'; }); }))].sort();
    if (AP_OPENTESTBUGS.some(function(b){ return !b.tests||!b.tests.length; })) statuses.push('No Tests');
    populateSelect('aptaAreaFilter', areas);
    populateSelect('aptaFuncFilter', funcs);
    populateSelect('aptaAutoFilter', statuses);

    window.renderAPTestAutoTable = function(){
      var search   = (document.getElementById('aptaSearch')||{}).value||'';
      var areaF    = (document.getElementById('aptaAreaFilter')||{}).value||'';
      var funcF    = (document.getElementById('aptaFuncFilter')||{}).value||'';
      var autoF    = (document.getElementById('aptaAutoFilter')||{}).value||'';
      var sl = search.toLowerCase();

      var rows = AP_OPENTESTBUGS.filter(function(b){
        var area = b.areaShort||b.areaPath||'';
        var func = b.functionality||'';
        var tests = b.tests||[];
        var statuses = tests.length ? tests.map(function(t){ return t.automationStatus||'Not Set'; }) : ['No Tests'];
        if (areaF && area !== areaF) return false;
        if (funcF && func !== funcF) return false;
        if (autoF && statuses.indexOf(autoF)<0) return false;
        if (sl && !(b.title.toLowerCase().includes(sl)||area.toLowerCase().includes(sl)||func.toLowerCase().includes(sl))) return false;
        return true;
      });

      if (!rows.length){
        document.getElementById('aptaTable').innerHTML = '<p style="color:#666;font-size:.9rem">No results.</p>';
        return;
      }

      var th = '<th style="padding:7px 10px;background:#eceff1;text-align:left;font-size:.82rem;border-bottom:1px solid #ccc">';
      var html = '<table style="width:100%;border-collapse:collapse;font-size:.82rem">';
      html += '<thead><tr>'+th+'ID</th>'+th+'Title</th>'+th+'Source</th>'+th+'Area Path</th>'+th+'Module</th>'+th+'Linked Tests &amp; Status</th>'+th+'Possible Fix</th></tr></thead><tbody>';

      rows.forEach(function(b, i){
        var bg = i%2===0?'#fff':'#f9fafb';
        var tests = b.tests||[];
        var testCell;
        if (!tests.length){
          testCell = '<span style="background:#bdbdbd;color:#fff;padding:2px 7px;border-radius:10px;font-size:.78rem">No Tests</span>';
        } else {
          testCell = tests.map(function(t){
            var col = statusColor(t.automationStatus||'Not Set');
            return '<div style="margin-bottom:2px"><a href="https://highq-tech.visualstudio.com/HighQ%20Tech/_workitems/edit/'+t.id+'" target="_blank" style="color:#1565c0;text-decoration:none;font-size:.78rem">#'+t.id+'</a> <span style="background:'+col+';color:#fff;padding:1px 6px;border-radius:10px;font-size:.75rem">'+(t.automationStatus||'Not Set')+'</span></div>';
          }).join('');
        }
        var td = 'style="padding:6px 10px;border-bottom:1px solid #e0e0e0;vertical-align:top"';
        html += '<tr style="background:'+bg+'">';
        html += '<td '+td+'><a href="'+b.url+'" target="_blank" style="color:#1565c0;text-decoration:none">#'+b.id+'</a></td>';
        html += '<td '+td+'>'+b.title+'</td>';
        html += '<td '+td+'>'+(b.issueSource||'')+'</td>';
        html += '<td '+td+'>'+(b.areaShort||b.areaPath||'')+'</td>';
        html += '<td '+td+'>'+(b.functionality||'')+'</td>';
        html += '<td '+td+'>'+testCell+'</td>';
        html += '<td '+td+' style="color:#555;font-size:.78rem">'+possibleFix(b.description)+'</td>';
        html += '</tr>';
      });
      html += '</tbody></table>';
      html += '<div style="margin-top:8px;font-size:.8rem;color:#666">Showing '+rows.length+' of '+AP_OPENTESTBUGS.length+' bugs</div>';
      document.getElementById('aptaTable').innerHTML = html;
    };

    window.exportAPTestAutoCSV = function(){
      var rows = [['ID','Title','Source','Area Path','Module','Test IDs','Automation Statuses','Possible Fix']];
      AP_OPENTESTBUGS.forEach(function(b){
        var tests = b.tests||[];
        rows.push([
          b.id,
          '"'+(b.title||'').replace(/"/g,'""')+'"',
          b.issueSource||'',
          '"'+(b.areaShort||b.areaPath||'').replace(/"/g,'""')+'"',
          '"'+(b.functionality||'').replace(/"/g,'""')+'"',
          '"'+tests.map(function(t){return t.id;}).join('; ')+'"',
          '"'+tests.map(function(t){return t.automationStatus||'Not Set';}).join('; ')+'"',
          '"'+possibleFix(b.description).replace(/"/g,'""')+'"'
        ]);
      });
      var csv = rows.map(function(r){return r.join(',');}).join('\n');
      var a = document.createElement('a');
      a.href = 'data:text/csv;charset=utf-8,'+encodeURIComponent(csv);
      a.download = 'ap-test-automation.csv';
      a.click();
    };

    renderAPTestAutoTable();
  } // end buildTestAutCharts

})();
</script>

</body>
</html>
